meta {
  name: Get Object Store Secret
  type: http
  seq: 2
}

get {
  url: {{AI_API_URL}}/v2/admin/objectStoreSecrets/default
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{TOKEN}}
  AI-Resource-Group: {{RESOURCE_GROUP}}
  Content-Type: application/json
}

docs {
  ## Get Object Store Secret

  Retrieves the details of a registered object store secret by name.
  Replace `default` in the URL with your secret name if different.
}
